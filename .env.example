# ── API Server ────────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=production
SESSION_SECRET=change-me-to-a-long-random-string

# Google OAuth (from console.cloud.google.com)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://your-api.railway.app/api/auth/google/callback

# Frontend URL (for CORS)
FRONTEND_URL=https://your-app.vercel.app

# Processor URL — set to Modal endpoint after deploying processor
PROCESSOR_URL=https://your-workspace--myoukee-processor-serve.modal.run

# ── Karaoke Processor ─────────────────────────────────────────────────────────
DEMUCS_DEVICE=cuda        # cuda on Modal H100, cpu locally
WHISPER_DEVICE=cuda       # cuda on Modal H100, cpu locally

# ── Cloudflare R2 (optional — for persistent file storage) ────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=myoukee-jobs

# ── GitHub Actions secrets (set in repo Settings → Secrets) ──────────────────
# VERCEL_TOKEN          — from vercel.com/account/tokens
# VERCEL_ORG_ID         — from vercel.com/account
# VERCEL_PROJECT_ID     — from vercel project settings
# RAILWAY_TOKEN         — from railway.app/account/tokens
# MODAL_TOKEN_ID        — from modal.com/settings
# MODAL_TOKEN_SECRET    — from modal.com/settings
